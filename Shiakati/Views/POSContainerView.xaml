<UserControl x:Class="Shiakati.Views.POSContainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:Shiakati.Views"
             FontFamily="{StaticResource MontserratFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
  <!-- Here we can add horizontal stackpanel and add features to caisse-->
        <Button Grid.Row="0" HorizontalAlignment="Right" Margin="0,0,10,0"
                Command="{Binding AddNewTabCommand}"
                Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center"/>
                <TextBlock Text="Nouveau Client" Margin="5,0,0,0"/>
            </StackPanel>
        </Button>

        <TabControl Grid.Row="1" 
                    ItemsSource="{Binding PosTabs}" 
                    SelectedItem="{Binding SelectedTab}"
                    Style="{StaticResource MaterialDesignTabControl}">

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="1">
                        <TextBlock Text="{Binding TabName}" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>

                        <Button Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                Width="24" Height="24" Margin="10,-8,0,0" ToolTip="Fermer le ticket">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <views:PosView />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>