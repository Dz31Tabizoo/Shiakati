<UserControl x:Class="Shiakati.Views.SalesHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024"
             FontFamily="{StaticResource MontserratFont}"
             Background="{DynamicResource MaterialDesignPaper}"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Margin="0,0,0,16" Padding="16" UniformCornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" 
                         Text="{Binding SearchTicketNumber, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Scanner QR Code ou N° Ticket"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding LoadSalesCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <DatePicker Grid.Column="1" 
                            SelectedDate="{Binding StartDate}"
                            materialDesign:HintAssist.Hint="Date de début"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,16,0" VerticalAlignment="Center"/>

                <DatePicker Grid.Column="2" 
                            SelectedDate="{Binding EndDate}"
                            materialDesign:HintAssist.Hint="Date de fin"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,16,0" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding LoadSalesCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,0" Content="Rechercher" Cursor="Hand"/>

                    <Button Command="{Binding ClearFiltersCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="Réinitialiser" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <ProgressBar Grid.Row="1" VerticalAlignment="Top" 
                     IsIndeterminate="True" 
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                     Panel.ZIndex="1"/>

        <materialDesign:Card Grid.Row="1" UniformCornerRadius="8">
            <DataGrid ItemsSource="{Binding Sales}" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      IsReadOnly="True"
                      HeadersVisibility="All"
                      materialDesign:DataGridAssist.CellPadding="12"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="12">
                <DataGrid.Columns>

                    <DataGridTextColumn Header="N° Ticket" Binding="{Binding TicketNumber}" Width="*"/>

                    <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=dd/MM/yyyy HH:mm}" Width="*"/>

                    <DataGridTextColumn Header="Montant Total" Binding="{Binding TotalAmount, StringFormat={}{0:N2} DA}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Remise" Binding="{Binding GlobalDiscount, StringFormat={}{0:N2} DA}" Width="*"/>

                    <DataGridTemplateColumn Header="Actions" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Voir les détails / Modifier"
                                            Command="{Binding DataContext.ViewSaleDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Edit" Foreground="{StaticResource PrimaryBrush}" />
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Annuler la vente / Rembourser"
                                            Command="{Binding DataContext.VoidSaleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="DeleteRestore" Foreground="Red" />
                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>