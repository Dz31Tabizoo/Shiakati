<UserControl x:Class="Shiakati.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Shiakati.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024"
             FontFamily="{StaticResource MontserratFont}">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="628*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Padding="10" UniformCornerRadius="8" Margin="0,0,0,10" Grid.ColumnSpan="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <materialDesign:PackIcon Kind="Magnify" Width="24" Height="24" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 materialDesign:HintAssist.Hint="Rechercher par Nom du produit ou SKU..."
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Width="400" FontSize="16" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="RÉINITIALISER LES FILTRES" Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Command="{Binding ClearFiltersCommand}" VerticalAlignment="Center"/>
                    <Button  Grid.Column="2" Content="RECESPTION FOURNISSEUR" Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Command="{Binding IsReseptionSuplyON}" VerticalAlignment="Center"/>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Padding="15,10" UniformCornerRadius="8" Margin="0,0,0,573" Grid.ColumnSpan="2" Grid.RowSpan="2">
                <WrapPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="CategoryName" SelectedItem="{Binding SelectedCategory}"
                              materialDesign:HintAssist.Hint="Catégorie" Width="150" Margin="0,0,15,10" Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>

                    <ComboBox ItemsSource="{Binding Brands}" DisplayMemberPath="BrandName" SelectedItem="{Binding SelectedBrand}"
                              materialDesign:HintAssist.Hint="Marque" Width="150" Margin="0,0,15,10" Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>

                    <TextBox Text="{Binding FilterColor, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Couleur" Width="100" Margin="0,0,15,10"/>

                    <TextBox Text="{Binding FilterLength, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Longueur" Width="80" Margin="0,0,15,10"/>
                    <TextBox Text="{Binding FilterWidth, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Largeur" Width="80" Margin="0,0,15,10"/>
                </WrapPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" UniformCornerRadius="8" Padding="5" Grid.ColumnSpan="2" Margin="0,35,0,0">
                <DataGrid ItemsSource="{Binding FilteredStock}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                          SelectionMode="Single" SelectedItem="{Binding SelectedStockItem}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Produit" Binding="{Binding ProductInfo.ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Marque" Binding="{Binding ProductInfo.BrandID}" />
                        <DataGridTextColumn Header="Couleur" Binding="{Binding Color}"/>
                        <DataGridTextColumn Header="Taille" Binding="{Binding FullSize}"/>
                        <DataGridTextColumn Header="En Stock" Binding="{Binding StockQuantity}" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTextColumn Header="Prix Achat" Binding="{Binding PurchasePrice, StringFormat={}{0:N2} DA}" Foreground="Crimson"/>
                        <DataGridTextColumn Header="Prix Vente" Binding="{Binding SalePrice, StringFormat={}{0:N2} DA}" Foreground="Green"/>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>
        </Grid>
        
        <materialDesign:Card Grid.Column="1" Width="350" UniformCornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <materialDesign:PackIcon Kind="TruckDeliveryOutline" Width="28" Height="28" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Réception Fournisseur" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="1. Informations Produit" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,10"/>
                        
                        <ComboBox IsEditable="False" materialDesign:HintAssist.Hint="Categories" 
                                  Text="{Binding Categories}" ItemsSource="{Binding AllCategories}" Margin="0,0,0,15"/>
                        <ComboBox ItemsSource="{Binding Brands}" DisplayMemberPath="BrandName" SelectedItem="{Binding DraftBrand}"
                                  materialDesign:HintAssist.Hint="Marque" Margin="0,0,0,15"/>

                        <ComboBox IsEditable="True" materialDesign:HintAssist.Hint="Nom du produit (Rechercher ou Saisir nouveau)" 
                                  Text="{Binding DraftProductName}" ItemsSource="{Binding AllProductNames}" Margin="0,0,0,22"/>

                       

                        <TextBlock Text="2. Détails du Produit" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,10"/>

                        <TextBox materialDesign:HintAssist.Hint="Code-barres (SKU)" IsEnabled="False" Text="{Binding DraftSKU}" Margin="0,0,0,10">
                            <TextBox.ToolTip>Laissez vide pour générer un code automatiquement</TextBox.ToolTip>
                        </TextBox>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>                            
                            

                            <ComboBox IsEditable="True" ItemsSource="{Binding AllColors}" DisplayMemberPath="Colors" SelectedItem="{Binding DraftColor}"
                                      materialDesign:HintAssist.Hint="Couleur" Margin="0,0,5,0"/>

                            <ComboBox Grid.Column="1" ItemsSource="{Binding AllSizes}" DisplayMemberPath="Taille largeur" SelectedItem="{Binding Width}"
                                      materialDesign:HintAssist.Hint="Taille (largeur)" Margin="0,0,5,0"/>

                            <TextBox  Grid.Column="2" materialDesign:HintAssist.Hint="Taille (longeur)" Text="{Binding DraftSize}" Margin="0,0,5,0"/>

                            <TextBox  Grid.Column="3" materialDesign:HintAssist.Hint="Taille (numérique)" Text="{Binding DraftFreeNumiricSize}" Margin="0,0,5,0"/>


                        </Grid>

                        <Separator Style="{StaticResource MaterialDesignSeparator}"  Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                        
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Prix d'achat" Text="{Binding DraftPurchasePrice}" Margin="0,0,5,0"/>
                            
                            <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Prix de vente" Text="{Binding DraftSalePrice}" Margin="5,0,0,0"/>

                            <TextBox   Grid.Row="1" Grid.Column="1" materialDesign:HintAssist.Hint="Remise fixe" Text="{Binding DraftFixedDiscount}" Margin="5,5,0,0"/>

                        </Grid>

                        <TextBlock Text="3. Quantité et Impression" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,10"/>

                        <TextBox materialDesign:HintAssist.Hint="Quantité reçue"  Text="{Binding DraftQuantity}" 
                                 FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <CheckBox Content="Imprimer les étiquettes de code-barres" IsChecked="{Binding PrintLabelsOnSave}" 
                                  Margin="0,0,0,10" FontWeight="SemiBold"/>

                        <TextBlock Text="Une étiquette sera imprimée pour chaque article." FontStyle="Italic" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="ENREGISTRER &amp; IMPRIMER" Height="50" FontSize="16" FontWeight="Bold"
                        Command="{Binding ReceiveStockCommand}" Margin="0,15,0,0"/>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
