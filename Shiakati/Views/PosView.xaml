<UserControl x:Class="Shiakati.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FontFamily="{StaticResource MontserratFont}">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Padding="10" UniformCornerRadius="10" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="BarcodeScan" Width="30" Height="30" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" Margin="10,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Scanner un code-barres ou chercher un produit..."
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Width="500" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>

            <ScrollViewer Grid.Row="1"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Disabled"
              Margin="0,0,0,15"
              materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True"
              materialDesign:ScrollViewerAssist.SupportHorizontalScroll="True"
              PanningMode="HorizontalOnly"         
              PanningDeceleration="0.5"               
              PanningRatio="1.0">


                <StackPanel Orientation="Horizontal">
                    <Button Content="TOUT" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,10,0"/>
                    <Button Content="THOBES" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="Pantalon" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="CHAUSSURES" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="Sous-vêtements" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="Cosmetique" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="Accessoires" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="Sadjadat" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="Chaises" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    
                </StackPanel>
            </ScrollViewer>

            <ListBox Grid.Row="2" ItemsSource="{Binding FilteredProducts}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                CommandParameter="{Binding}"
                                Style="{StaticResource MaterialDesignFlatButton}" 
                                Padding="0" Margin="5" Height="140" Width="140">
                            <materialDesign:Card UniformCornerRadius="10" Background="White" Width="140" Height="140">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <materialDesign:PackIcon Grid.Row="0" Kind="TshirtCrew" Width="60" Height="60" 
                                                             HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" Opacity="0.5"/>

                                    <Border Grid.Row="1" Background="{StaticResource BgBrush}" Padding="5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductInfo.ProductName}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SalePrice, StringFormat={}{0:N2} DA}" Foreground="{StaticResource SecondaryBrush}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </materialDesign:Card>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <materialDesign:Card Grid.Column="1" UniformCornerRadius="15" Background="White">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Ticket Actuel" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding CartItems}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Article" Width="Auto" MinWidth="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" 
                                               FontSize="15" TextWrapping="Wrap" Margin="0,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Qté" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                Width="32" Height="32" Padding="0"
                                                Command="{Binding DataContext.DecrementQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="MinusCircle"/>
                                        </Button>
                                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"/>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                Width="32" Height="32" Padding="0"
                                                Command="{Binding DataContext.IncrementQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="PlusCircle"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Remises" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">

                                        <ToggleButton Style="{StaticResource MaterialDesignActionToggleButton}"
                                                      IsChecked="{Binding IsDiscountPinned}"
                                                      Command="{Binding ToggleDiscountCommand}"
                                                      Width="40" Height="40"
                                                      Background="Transparent" BorderThickness="1"
                                                      ToolTip="Remise fixe du produit">
                                            <ToggleButton.Content>
                                                <materialDesign:PackIcon Kind="TagOutline" Width="20" Height="20" Foreground="Gray"/>
                                            </ToggleButton.Content>
                                            <materialDesign:ToggleButtonAssist.OnContent>
                                                <materialDesign:PackIcon Kind="Tag" Width="20" Height="20" Foreground="#FF9800"/>
                                            </materialDesign:ToggleButtonAssist.OnContent>
                                        </ToggleButton>

                                        <TextBox Text="{Binding ManualDiscount, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="70" Margin="10,0,0,0" Padding="5,5,5,5"
                                                 materialDesign:HintAssist.Hint="DA"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 VerticalAlignment="Center" TextAlignment="Center"
                                                 FontSize="14" FontWeight="SemiBold" Foreground="#FF9800"/>

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Total" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:N2}}" 
                                               VerticalAlignment="Center" FontWeight="Bold" 
                                               Foreground="{StaticResource PrimaryBrush}" Margin="10,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Foreground="Crimson">
                                        <materialDesign:PackIcon Kind="CartRemove" Width="24" Height="24"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                
                <StackPanel Grid.Row="2" Margin="0,15,0,0">
                    <Separator Margin="0,0,0,10"/>
                    <Grid Margin="0,5">
                        <TextBlock Text="Sous-total :" FontSize="16"/>
                        <TextBlock Text="{Binding CartSubTotal, StringFormat={}{0:N2} DA}" 
                   FontSize="16" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <TextBlock Text="Remise :" FontSize="16" Foreground="Green"/>
                        <TextBlock Text="{Binding TotalDiscountAmount, StringFormat={}-{0:N2} DA}" 
                   FontSize="16" HorizontalAlignment="Right" Foreground="Green"/>
                    </Grid>

                    <Grid Margin="0,15">
                        <TextBlock Text="TOTAL À PAYER" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding CartTotal, StringFormat={}{0:N2} DA}" 
                   FontSize="32" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource SecondaryBrush}"/>
                    </Grid>

                    <Button Content="ENCAISSER (F12)" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="{StaticResource SecondaryBrush}" 
                            BorderBrush="{x:Null}" Foreground="White"
                            Height="70" FontSize="24" FontWeight="Bold"
                            Command="{Binding CheckoutCommand}">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>