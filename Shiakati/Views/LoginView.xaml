 <Window x:Class="Shiakati.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Connexion - Shiakati POS"
        Height="620"
        Width="1020"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource MontserratFont}">

    <!-- Main Card -->
    <Border CornerRadius="22"
            Background="{DynamicResource BgBrush}"
            Margin="25">

        <Border.Effect>
            <DropShadowEffect BlurRadius="25"
                              ShadowDepth="3"
                              Opacity="0.25"/>
        </Border.Effect>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    CornerRadius="22,0,0,22"
                    Background="{DynamicResource PrimaryBrush}">

                <Grid>

                    <!-- Gradient Overlay -->
                    <Border Opacity="0.08">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="White"/>
                                <GradientStop Offset="1" Color="Transparent"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,10">

                        <!-- Title -->
                        <TextBlock Text="شياكتي"
                                   FontFamily="{StaticResource CairoFont}"
                                   FontSize="62"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BgBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="أسلوب حياتي"
                                   FontSize="20"
                                   FontFamily="{StaticResource CairoFont}"
                                   Foreground="{DynamicResource SecondaryHueMidBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,-12,0,10"/>

                        <!-- Logo -->
                        <Image Source="/Resources/Photos/Shiakati beige Logo.png"
                               Width="230"
                               Height="300"
                               Stretch="Uniform"
                               Margin="0,10,0,20"/>

                        <!-- Footer Logo -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Opacity="0.55">

                            <Image Source="/Resources/Photos/NumidixLogoSQR.png"
                                   Width="60"
                                   Height="60"
                                   Margin="5"
                                   Stretch="Uniform"/>

                            <TextBlock Text="Numidix Lab"
                                       FontSize="24"
                                       FontFamily="{StaticResource PoppinsFont}"
                                       Foreground="{DynamicResource SecondaryHueMidBrush}"
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>
                        </StackPanel>

                    </StackPanel>

                </Grid>

            </Border>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="1"
                  Margin="60">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Close Button -->
                <Button Grid.Row="0"
                        HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Click="BtnClose_Click"
                        Foreground="Gray">

                    <materialDesign:PackIcon Kind="Close"
                                             Width="26"
                                             Height="26"/>
                </Button>

                <!-- Login Content -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            Margin="10">

                    <TextBlock Text="Bienvenue / مرحباً"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Veuillez vous connecter pour continuer"
                               FontSize="16"
                               Foreground="Gray"
                               Margin="0,0,0,35"/>

                    <!-- Username -->
                    <TextBox x:Name="TxtUsername"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Nom d'utilisateur / اسم المستخدم"
                             materialDesign:HintAssist.Foreground="{DynamicResource PrimaryBrush}"
                             materialDesign:TextFieldAssist.UnderlineCornerRadius="10"
                             FontSize="18"
                             Height="60"
                             Margin="0,0,0,22"/>

                    <!-- Password -->
                    <PasswordBox x:Name="TxtPassword"
                                 Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
                                 materialDesign:HintAssist.Hint="Mot de passe / كلمة المرور"
                                 materialDesign:HintAssist.Foreground="{DynamicResource PrimaryBrush}"
                                 materialDesign:TextFieldAssist.UnderlineCornerRadius="10"
                                 FontSize="18"
                                 Height="60"
                                 Margin="0,0,0,10"/>

                    <!-- Error Message -->
                    <TextBlock x:Name="TxtErrorMessage"
                               Text="Identifiants incorrects."
                               Foreground="#E53935"
                               Visibility="Collapsed"
                               Margin="5,0,0,15"/>

                    <!-- Login Button -->
                    <Button x:Name="BtnLogin"
                            Content="SE CONNECTER"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource SecondaryBrush}"
                            BorderBrush="{DynamicResource SecondaryBrush}"
                            Foreground="White"
                            materialDesign:ButtonAssist.CornerRadius="18"
                            FontSize="20"
                            FontWeight="Bold"
                            Height="65"
                            Margin="0,15,0,0"
                            Click="BtnLogin_Click">

                        <Button.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.35"/>
                        </Button.Effect>

                    </Button>

                </StackPanel>

                <!-- Footer -->
                <TextBlock Grid.Row="2"
                           Text="Shiakati POS v1.0 © 2026"
                           Foreground="#BDBDBD"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>

            </Grid>

        </Grid>

    </Border>

</Window>

