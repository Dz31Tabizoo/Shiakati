        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="{StaticResource MontserratFont}">

    --><!-- Main container with glass-morphism effect and modern shadow --><!--
    <Border CornerRadius="30" Background="{DynamicResource BgBrush}" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="35" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            --><!-- LEFT PANEL - Branding Area (Modernized centered layout) --><!--
            <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="30,0,0,30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    --><!-- Spacer / decorative top (keeps content balanced) --><!--
                    <StackPanel Grid.Row="0" Height="20"/>

                    --><!-- Centered brand content --><!--
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="شياكتي" 
                                   FontFamily="{StaticResource CairoFont}" 
                                   FontSize="64"
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource BgBrush}" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="أسلوب حياتي" 
                                   FontSize="20" 
                                   FontFamily="{DynamicResource CairoFont}"
                                   Foreground="{DynamicResource SecondaryHueMidBrush}" 
                                   HorizontalAlignment="Center"
                                   Margin="0,-15,0,30"
                                   Opacity="0.9"/>

                        --><!-- Main Logo - same size as requested --><!--
                        <Image Source="/Resources/Photos/Shiakati beige Logo.png" 
                               Width="230" 
                               Height="300"
                               Margin="0,10,0,20"
                               Stretch="Fill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </StackPanel>

                    --><!-- Bottom section with Numidix branding --><!--
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Left" 
                                Margin="25,0,0,25"
                                Opacity="0.85">
                        <Image Source="/Resources/Photos/NumidixLogoSQR.png" 
                               Width="70" 
                               Height="70"
                               Margin="0,0,10,0"
                               Stretch="Fill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Numidix Lab" 
                                   FontSize="22"
                                   FontFamily="{StaticResource PoppinsFont}"
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource SecondaryHueMidBrush}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            --><!-- RIGHT PANEL - Login Form (Modern, with icons and refined spacing) --><!--
            <Grid Grid.Column="1" Margin="45,35,45,35">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                --><!-- Close button - modern circular with hover effect --><!--
                <Button Grid.Row="0" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Background="Transparent"
                        Foreground="#909090"
                        Width="36"
                        Height="36"
                        Click="BtnClose_Click"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="18"/>
                        </Style>
                    </Button.Resources>
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0"/>
                    </Button.Effect>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignToolButton}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                --><!-- Form Content --><!--
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    --><!-- Welcome Section --><!--
                    <TextBlock Text="Bienvenue / مرحباً" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryBrush}" 
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Veuillez vous connecter pour continuer" 
                               FontSize="15" 
                               Foreground="#808080" 
                               Margin="0,0,0,45"
                               Opacity="0.9"/>

                    --><!-- Username Field with Leading Icon --><!--
                    <TextBox x:Name="TxtUsername" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Nom d'utilisateur / اسم المستخدم"
                             materialDesign:HintAssist.Foreground="{DynamicResource PrimaryBrush}"
                             materialDesign:HintAssist.HintOpacity="0.7"
                             materialDesign:TextFieldAssist.UnderlineCornerRadius="12"
                             materialDesign:TextFieldAssist.LeadingIcon="Account"
                             FontSize="16" 
                             Height="58" 
                             Margin="0,0,0,25"
                             VerticalContentAlignment="Center"/>

                    --><!-- Password Field with Leading Icon (Reveal support) --><!--
                    <PasswordBox x:Name="TxtPassword" 
                                 Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
                                 materialDesign:HintAssist.Hint="Mot de passe / كلمة المرور"
                                 materialDesign:HintAssist.Foreground="{DynamicResource PrimaryBrush}"
                                 materialDesign:HintAssist.HintOpacity="0.7"
                                 materialDesign:TextFieldAssist.UnderlineCornerRadius="12"
                                 materialDesign:TextFieldAssist.LeadingIcon="Lock"
                                 FontSize="16" 
                                 Height="58" 
                                 Margin="0,0,0,15"
                                 VerticalContentAlignment="Center"/>

                    --><!-- Modern Error Message with Icon and Background --><!--
                    <Border x:Name="ErrorBorder"
                            Background="#FFF2F2"
                            CornerRadius="12"
                            Padding="12,10"
                            Margin="0,5,0,20"
                            BorderBrush="#FFCDD2"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircle" 
                                                     Foreground="#D32F2F" 
                                                     Width="20" 
                                                     Height="20" 
                                                     Margin="0,0,12,0"
                                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtErrorMessage" 
                                       Text="Identifiants incorrects." 
                                       Foreground="#D32F2F" 
                                       FontSize="13"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    --><!-- Login Button with enhanced modern effects --><!--
                    <Button x:Name="BtnLogin" 
                            Content="SE CONNECTER" 
                            Background="{DynamicResource SecondaryBrush}"
                            BorderBrush="{DynamicResource SecondaryBrush}"
                            Foreground="White"
                            materialDesign:ButtonAssist.CornerRadius="18"
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Height="62" 
                            Margin="0,15,0,0"
                            Cursor="Hand"
                            Click="BtnLogin_Click">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
                        </Button.Effect>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="18"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SecondaryHueMidBrush}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.35" Color="#000000"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                --><!-- Version Footer --><!--
                <TextBlock Grid.Row="2" 
                           Text="Shiakati POS v1.0 © 2026" 
                           Foreground="#C0C0C0" 
                           HorizontalAlignment="Center" 
                           FontSize="12"
                           Margin="0,15,0,5"
                           Opacity="0.8"/>
            </Grid>
        </Grid>
    </Border>
</Window>-->
