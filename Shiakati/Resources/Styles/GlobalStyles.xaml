<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Style x:Key="ShiakatiCard" TargetType="materialDesign:Card">
        <Setter Property="UniformCornerRadius" Value="15"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3"/>
        <Setter Property="Margin" Value="5"/>
    </Style>

    <Style x:Key="ShiakatiMenuButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Height" Value="120"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="15"/>
    </Style>

</ResourceDictionary>